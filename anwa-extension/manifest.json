{
  "manifest_version": 3,
  "name": "ANWA DJ Token",
  "version": "1.3",
  "description": "Capture automatiquement le token Spotify depuis la console développeur",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://api.spotify.com/*",
    "https://dj.anwadance.com/*",
    "https://developer.spotify.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://developer.spotify.com/*"],
      "js": ["content_main.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://developer.spotify.com/*"],
      "js": ["content_isolated.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon.png"
    }
  },
  "icons": {
    "48": "icon.png"
  }
}
